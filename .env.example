# ── Plane ─────────────────────────────────────────────────────────────────────
PLANE_API_KEY=plane-api-key-here
PLANE_BASE_URL=https://plane.yourdomain.com
PLANE_WORKSPACE_SLUG=your-workspace-slug
PLANE_PROJECT_ID=843806f5-9782-4fe8-86d9-249eebd911b8
WEBHOOK_SECRET=secret-from-plane-webhook-settings

# ── GitHub ─────────────────────────────────────────────────────────────────────
# PAT needs: repo, workflow scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── AI providers ───────────────────────────────────────────────────────────────
# Add keys for providers you use in sukhoi.config.json
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# ── Runtime ────────────────────────────────────────────────────────────────────
PORT=3000
CONCURRENCY=1
JOB_TIMEOUT_MS=600000

# ── Runner ─────────────────────────────────────────────────────────────────────
# Internal path to the repo cache volume (mounted via docker-compose).
# Change only if you override the volume mount path in docker-compose.yml.
# REPO_CACHE_DIR=/repo-cache

# ── OpenCode ───────────────────────────────────────────────────────────────────
# Optional: path to an opencode config file inside the container.
# Mount your config file into the container via docker-compose volumes, then
# set this to the in-container path. The file is copied to
# ~/.config/opencode/config.json before each job so OpenCode picks up
# MCP servers, model settings, etc.
# OPENCODE_CONFIG_PATH=/opencode.json
